---
import fs from 'node:fs';
import type { OpenAPISpec } from '~/components/ApiReference/openapi';
import {
  groupByTag,
  humanizeTag,
  preprocessSchema,
  slugifyTag,
  TAG_DESCRIPTIONS,
} from '~/components/ApiReference/openapi';
import MainLayout from '~/layouts/MainLayout.astro';
import '~/styles/api-reference.css';

const rawSchema: OpenAPISpec = JSON.parse(fs.readFileSync('public/api-schemas.json', 'utf-8'));
const schema = preprocessSchema(rawSchema);
const groups = groupByTag(schema);
const baseUrl = schema.servers[0]?.url ?? 'https://api.mergify.com/v1';

const sections = [...groups.entries()].map(([tag, endpoints]) => ({
  tag,
  label: humanizeTag(tag),
  slug: slugifyTag(tag),
  description: TAG_DESCRIPTIONS[tag] ?? '',
  count: endpoints.length,
  methods: [...new Set(endpoints.map((e) => e.method))],
}));

const headings = sections.map((s) => ({
  depth: 2,
  slug: s.slug,
  text: s.label,
}));

const content = {
  title: 'API Reference',
  description: 'Complete reference for the Mergify REST API',
};
---

<MainLayout content={content} headings={headings} showMarkdownActions={false}>
  <div class="api-reference">
    <div class="api-intro">
      <div class="api-base-url">
        <span class="api-label">Base URL</span>
        <code>{baseUrl}</code>
      </div>
      <div class="api-auth-summary">
        <span class="api-label">Authentication</span>
        <p>
          All endpoints require a Bearer token. Two authentication methods are
          supported:
        </p>
        <ul>
          <li>
            <strong>Application Key</strong> — generated from your Mergify
            dashboard
          </li>
          <li>
            <strong>GitHub Token</strong> — a GitHub personal access token (<code
              >ghp_*</code
            >, <code>github_pat_*</code>, or <code>gho_*</code>)
          </li>
        </ul>
        <p>
          See <a href="/api-usage">API Usage</a> for setup instructions.
        </p>
      </div>
    </div>

    <div class="api-section-grid">
      {
        sections.map((section) => (
          <a
            href={`/api/${section.slug}`}
            class="api-section-card"
            id={section.slug}
          >
            <div class="api-section-card-head">
              <h2>{section.label}</h2>
              <span class="api-section-count">
                {section.count} endpoint{section.count !== 1 ? 's' : ''}
              </span>
            </div>
            {section.description && (
              <p class="api-section-description">{section.description}</p>
            )}
            <div class="api-section-methods">
              {section.methods.map((m) => (
                <span class={`method-badge method-${m.toLowerCase()}`}>
                  {m}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </div>
</MainLayout>
