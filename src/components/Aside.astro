---
import { Icon } from 'astro-icon/components';

export interface Props {
  type?: 'note' | 'tip' | 'caution' | 'danger';
  title?: string;
}

const titles = {
  note: 'Note',
  tip: 'Tip',
  caution: 'Caution',
  danger: 'Danger',
};

const icons = {
  note: 'lucide:info',
  tip: 'lucide:lightbulb',
  caution: 'lucide:triangle-alert',
  danger: 'lucide:octagon-alert',
} as const;

const { type = 'note', title = titles[type] } = Astro.props as Props;
const iconName = icons[type];
---

<aside class={`content ${type}`} aria-label={title}>
  <p class="title" aria-hidden="true">
    <Icon name={iconName} width={16} height={16} class="icon" />
    {title}
  </p>
  <section>
    <slot />
  </section>
</aside>

<style>
  /* note (default) */
  aside {
    --aside-accent-color: var(--color-blue-400);
    --aside-text-accent-color: var(--color-blue-700);

    border-inline-start: 3px solid var(--aside-accent-color);
    border-radius: 0 8px 8px 0;
    padding: 0.875rem 1rem;
    background-color: color-mix(
      in srgb,
      var(--aside-accent-color) 8%,
      var(--theme-bg-content)
    );
    /* Indicates the aside boundaries for forced-colors users — transparent is
       remapped to a solid color in forced-colors mode. */
    outline: 1px solid transparent;
  }

  /* Dark-mode background applies to every variant via the cascade — each
     type's --aside-accent-color is already set by the time this resolves.
     8% reads too subtle against the dark bg, so dark uses 12%. */
  :global(.theme-dark) aside {
    --aside-text-accent-color: var(--color-blue-400);
    background-color: color-mix(
      in srgb,
      var(--aside-accent-color) 12%,
      var(--theme-bg-content)
    );
  }

  .title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    line-height: 1.4;
    margin-bottom: 0.25rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--aside-text-accent-color);
  }

  .icon {
    flex-shrink: 0;
  }

  aside :global(a),
  aside :global(a > code:not([class*='language'])) {
    color: var(--aside-text-accent-color);
  }

  aside :global(p),
  aside.content :global(ul) {
    color: var(--theme-text);
  }

  :global(.theme-dark) aside :global(code:not([class*='language'])) {
    color: var(--theme-code-text);
  }

  aside :global(pre) {
    margin-left: 0;
    margin-right: 0;
  }

  .tip {
    --aside-accent-color: var(--color-teal-400);
    --aside-text-accent-color: var(--color-teal-700);
  }
  :global(.theme-dark) .tip {
    --aside-text-accent-color: var(--color-teal-400);
  }

  .caution {
    --aside-accent-color: var(--color-orange-400);
    --aside-text-accent-color: var(--color-orange-700);
  }
  :global(.theme-dark) .caution {
    --aside-text-accent-color: var(--color-orange-400);
  }

  .danger {
    --aside-accent-color: var(--color-coral-400);
    --aside-text-accent-color: var(--color-coral-700);
  }
  :global(.theme-dark) .danger {
    --aside-text-accent-color: var(--color-coral-400);
  }
</style>
