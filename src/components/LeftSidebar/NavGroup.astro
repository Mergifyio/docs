---
import { Icon } from 'astro-icon/components';
import type { NavItem } from '~/content/navItems';
import NavLink from './NavLink.astro';
export interface Props {
  navGroup: NavItem;
  currentPageMatch: string;
  depth?: number;
}

const { navGroup, currentPageMatch, depth = 0 } = Astro.props as Props;
const isStringIcon = typeof navGroup.icon === 'string';
const IconComponent = !isStringIcon ? navGroup.icon : null;
---

<li class:list={{
	'nav-group': true,
	'active': true,
	'nav-group-merge-queue': navGroup.path?.startsWith('/merge-queue'),
	'nav-group-ci-insights': navGroup.path?.startsWith('/ci-insights'),
	'nav-group-merge-protections': navGroup.path?.startsWith('/merge-protections'),
	'nav-group-workflow': navGroup.path?.startsWith('/workflow')
}}>
	<nav-group data-uuid={navGroup.id}>
		<details>
			<summary class="nav-group-title" title={navGroup.title}>
				<h2>
					{depth === 0 && navGroup.icon && isStringIcon && <Icon name={navGroup.icon as string} class="left-icon" />}
					{depth === 0 && IconComponent && <IconComponent class="left-icon" />}
					<span class="nav-group-label">{navGroup.title}</span>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 1 16 16"
						width="16"
						height="16"
						aria-hidden="true"
						class="chevron"
					>
						<path
							fill-rule="evenodd"
							d="M6.22 3.22a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06L9.94 8 6.22 4.28a.75.75 0 010-1.06z"
						></path>
					</svg>
				</h2>
			</summary>
			<div class="nav-group-content">
				<ul>
					{
						navGroup.children?.map((child) => {
							return child.children ? (
								<Astro.self currentPageMatch={currentPageMatch} navGroup={child} depth={depth + 1} />
							) : (
								<NavLink currentPageMatch={currentPageMatch} navItem={child} showIcon={false} />
							);
						})
					}
				</ul>
			</div>
		</details>
	</nav-group>
</li>

<script>
	class NavGroup extends HTMLElement {
		constructor() {
			super();

			const uuid = this.dataset.uuid;
			const storedNavState = window.localStorage.getItem('navState');
			let isOpen = false;
			if (!uuid) {
				console.warn('No uuid found for nav-group');
				return;
			}
			if (storedNavState !== null && uuid) {
				const navState = JSON.parse(storedNavState);
				isOpen = navState[uuid];
			}

			// Use :scope > to only match this element's direct children, not nested nav-groups
			const navGroupDetails = this.querySelector(':scope > details');
			const navGroupTitle = this.querySelector(':scope > details > .nav-group-title');

			if (isOpen) {
				navGroupDetails?.setAttribute('open', '');
			} else {
				navGroupDetails?.removeAttribute('open');
			}

			navGroupTitle?.addEventListener('click', (e) => {
				e.preventDefault();
				e.stopPropagation();
				const storedNavState = window.localStorage.getItem('navState');
				let navState = { uuid: true };
				if (storedNavState !== null) {
					navState = JSON.parse(storedNavState);
					navState[uuid] = !navState[uuid];
				}
				window.localStorage.setItem('navState', JSON.stringify({ ...navState }));

				if (navGroupDetails?.hasAttribute('open')) {
					navGroupDetails.classList.add('closing');
					const content = navGroupDetails.querySelector(':scope > .nav-group-content');
					const onEnd = (e: Event) => {
						// Ignore bubbled transitionend events from nested nav-groups
						if (e.target !== content) return;
						navGroupDetails.removeAttribute('open');
						navGroupDetails.classList.remove('closing');
						content?.removeEventListener('transitionend', onEnd);
					};
					content?.addEventListener('transitionend', onEnd);
				} else {
					// Add opening class to hold grid at 0fr, set open, force reflow, then remove to trigger transition
					navGroupDetails?.classList.add('opening');
					navGroupDetails?.setAttribute('open', '');
					void (navGroupDetails as HTMLElement)?.offsetHeight; // force reflow
					navGroupDetails?.classList.remove('opening');
				}
			});
		}
	}

	customElements.define('nav-group', NavGroup);
</script>

<style lang="scss">
	.nav-group .placeholder {
		opacity: 0.6;
		text-align: center;
		display: block;
	}
	@media (min-width: 50em) {
		.nav-group {
			display: none;
			margin-bottom: 0.25rem;
		}
	}
	.nav-group.active {
		display: block;
	}
	.nav-group-title {
		font-size: 14px;
		font-weight: 400;
		padding: 0.4rem 0.75rem;
		color: var(--theme-text);

		h2 {
			display: flex;
			align-items: center;
			gap: 8px;
		}

		:global(.left-icon) {
			min-width: 16px;
			min-height: 16px;
			color: var(--theme-text-lighter);
		}
	}

	:global(:root.theme-dark) .nav-link a[aria-current='page'] {
		color: hsla(var(--color-base-white), 100%, 1);
	}

	.nav-group-content {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.2s ease;
	}

	details[open]:not(.closing):not(.opening) > .nav-group-content {
		grid-template-rows: 1fr;
	}

	.nav-group-content > ul {
		overflow: hidden;
		padding-left: 0.5rem !important;
		margin-left: 1.2rem;
		border-left: 1px solid var(--theme-divider);
	}

	details > summary {
		list-style: none;
	}

	details > summary::marker,
	details > summary::-webkit-details-marker {
		display: none;
	}

	details[open] > summary .chevron {
		transform: rotate(90deg);
	}

	summary {
		cursor: pointer;
	}

	summary h2 {
		all: inherit;
		margin: 0;
		padding: 0;
		width: 100%;
		overflow: hidden;
	}

	.nav-group-label {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.chevron {
		margin-left: auto;
		flex-shrink: 0;
		opacity: 0.4;
		width: 12px;
		height: 12px;
	}

	svg {
		transform: rotate(0);
		transition: 0.15s transform ease;
	}

	svg path {
		fill: currentColor;
	}
</style>
