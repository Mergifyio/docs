---
import { Icon } from 'astro-icon/components';
import type { NavItem } from '~/content/navItems';
import NavLink from './NavLink.astro';
export interface Props {
  navGroup: NavItem;
  currentPageMatch: string;
  depth?: number;
}

const { navGroup, currentPageMatch, depth = 0 } = Astro.props as Props;
const isStringIcon = typeof navGroup.icon === 'string';
const IconComponent = !isStringIcon ? navGroup.icon : null;
---

<li class:list={{
	'nav-group': true,
	'active': true,
	'nav-group-merge-queue': navGroup.path?.startsWith('/merge-queue'),
	'nav-group-ci-insights': navGroup.path?.startsWith('/ci-insights'),
	'nav-group-merge-protections': navGroup.path?.startsWith('/merge-protections'),
	'nav-group-workflow': navGroup.path?.startsWith('/workflow')
}}>
	<nav-group data-uuid={navGroup.id}>
		<div class="nav-details">
			<button class="nav-group-title" type="button" title={navGroup.title} aria-expanded="false">
				<h2>
					{depth === 0 && navGroup.icon && isStringIcon && <Icon name={navGroup.icon as string} class="left-icon" />}
					{depth === 0 && IconComponent && <IconComponent class="left-icon" />}
					<span class="nav-group-label">{navGroup.title}</span>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 1 16 16"
						width="16"
						height="16"
						aria-hidden="true"
						class="chevron"
					>
						<path
							fill-rule="evenodd"
							d="M6.22 3.22a.75.75 0 011.06 0l4.25 4.25a.75.75 0 010 1.06l-4.25 4.25a.75.75 0 01-1.06-1.06L9.94 8 6.22 4.28a.75.75 0 010-1.06z"
						></path>
					</svg>
				</h2>
			</button>
			<div class="nav-group-content" inert>
				<ul>
					{
						navGroup.children?.map((child) => {
							return child.children ? (
								<Astro.self currentPageMatch={currentPageMatch} navGroup={child} depth={depth + 1} />
							) : (
								<NavLink currentPageMatch={currentPageMatch} navItem={child} showIcon={false} />
							);
						})
					}
				</ul>
			</div>
		</div>
	</nav-group>
</li>

<script>
	function parseNavState(raw: string | null): Record<string, boolean> {
		if (raw === null) return {};
		try {
			const parsed = JSON.parse(raw);
			return typeof parsed === 'object' && parsed !== null ? parsed : {};
		} catch {
			return {};
		}
	}

	class NavGroup extends HTMLElement {
		constructor() {
			super();

			const uuid = this.dataset.uuid;
			if (!uuid) {
				console.warn('No uuid found for nav-group');
				return;
			}

			const navState = parseNavState(window.localStorage.getItem('navState'));
			const isOpen = !!navState[uuid];

			const wrapper = this.querySelector(':scope > .nav-details');
			const title = this.querySelector(':scope > .nav-details > .nav-group-title');
			const content = wrapper?.querySelector(':scope > .nav-group-content');

			if (isOpen && wrapper) {
				wrapper.classList.add('open');
				title?.setAttribute('aria-expanded', 'true');
				if (content) content.removeAttribute('inert');
			}

			// Enable transitions only after initial state is applied.
			// Without this, navigating between pages causes a visible
			// 0fr→1fr animation as the saved open state is restored.
			wrapper?.classList.add('ready');

			// The head-injected #nav-restore style should have been removed
			// by the LeftSidebar inline script already, but clean it up here
			// too as a fallback in case that script errored.
			document.getElementById('nav-restore')?.remove();

			title?.addEventListener('click', () => {
				const navState = parseNavState(window.localStorage.getItem('navState'));
				const shouldOpen = !wrapper?.classList.contains('open') &&
					!wrapper?.classList.contains('closing');

				navState[uuid] = shouldOpen;
				window.localStorage.setItem('navState', JSON.stringify(navState));

				if (!shouldOpen) {
					// Close: animate grid from 1fr → 0fr, then remove .open
					title?.setAttribute('aria-expanded', 'false');
					wrapper?.classList.add('closing');
					if (content) content.setAttribute('inert', '');
					const cleanup = () => {
						wrapper?.classList.remove('open', 'closing');
						content?.removeEventListener('transitionend', onEnd);
					};
					const onEnd = (e: Event) => {
						if (e.target !== content) return;
						clearTimeout(fallback);
						cleanup();
					};
					content?.addEventListener('transitionend', onEnd);
					// Fallback if transitionend never fires (e.g. prefers-reduced-motion)
					const fallback = setTimeout(cleanup, 250);
				} else {
					// Open: hold at 0fr via .opening, add .open, reflow, then release
					title?.setAttribute('aria-expanded', 'true');
					wrapper?.classList.remove('closing');
					wrapper?.classList.add('opening', 'open');
					if (content) content.removeAttribute('inert');
					void (wrapper as HTMLElement)?.offsetHeight; // force reflow
					wrapper?.classList.remove('opening');
				}
			});
		}
	}

	customElements.define('nav-group', NavGroup);
</script>

<style lang="scss">
	.nav-group .placeholder {
		opacity: 0.6;
		text-align: center;
		display: block;
	}
	@media (min-width: 50em) {
		.nav-group {
			display: none;
			margin-bottom: 0.25rem;
		}
	}
	.nav-group.active {
		display: block;
	}
	.nav-group-title {
		all: unset;
		display: block;
		width: 100%;
		box-sizing: border-box;
		font-size: 14px;
		font-weight: 400;
		padding: 0.4rem 0.75rem;
		color: var(--theme-text);
		cursor: pointer;

		&:focus-visible {
			outline: 2px solid var(--theme-accent);
			outline-offset: -2px;
			border-radius: 4px;
		}

		h2 {
			display: flex;
			align-items: center;
			gap: 8px;
		}

		:global(.left-icon) {
			min-width: 16px;
			min-height: 16px;
			color: var(--theme-text-lighter);
		}
	}

	:global(:root.theme-dark) .nav-link a[aria-current='page'] {
		color: hsla(var(--color-base-white), 100%, 1);
	}

	.nav-group-content {
		display: grid;
		grid-template-rows: 0fr;
	}

	@media (prefers-reduced-motion: no-preference) {
		.nav-details.ready > .nav-group-content {
			transition: grid-template-rows 0.2s ease;
		}

		.nav-details.ready .chevron {
			transition: 0.15s transform ease;
		}
	}

	.nav-details.open:not(.closing):not(.opening) > .nav-group-content {
		grid-template-rows: 1fr;
	}

	.nav-group-content > ul {
		overflow: hidden;
		padding-left: 0.5rem !important;
		margin-left: 1.2rem;
		border-left: 1px solid var(--theme-divider);
	}

	.open > .nav-group-title .chevron {
		transform: rotate(90deg);
	}

	.nav-group-title h2 {
		all: inherit;
		margin: 0;
		padding: 0;
		width: 100%;
		overflow: hidden;
	}

	.nav-group-label {
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.chevron {
		margin-left: auto;
		flex-shrink: 0;
		opacity: 0.4;
		width: 12px;
		height: 12px;
		transform: rotate(0);
	}
</style>
