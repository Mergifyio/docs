---
import { Icon } from 'astro-icon/components';

export interface Props {
  icon: string;
  alt: string;
}

const { icon, alt } = Astro.props;
---

<div class="comparison-logo" role="img" aria-label={alt}>
  <Icon name={icon} />
</div>

<style>
  .comparison-logo {
    float: right;
    margin-left: 1.5em;
    margin-bottom: 1em;
    width: 96px;
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .comparison-logo :global(svg) {
    width: 100%;
    height: 100%;
  }
</style>
