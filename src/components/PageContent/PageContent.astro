---
import { CollectionEntry } from 'astro:content';
export interface Props {
  content: CollectionEntry<'docs'>['data'];
}

const { content } = Astro.props;
// We wrap `@astrojs/` in a span to style it separately on integration pages.
const title = content.title
  .replace('@astrojs/', '<span class="scope">@astrojs/</span><wbr>')
  .replaceAll('-', '&#8288;-&#8288;');
const description = content.description;
const suppressTitle = content.suppressTitle;
---

<div dir={'ltr'} lang={'en'}>
	<article id="article" class="content">
		<section class="main-section">
			<header>
				<slot name="before-title" />
				{!suppressTitle && <h1 class="content-title" id="overview" set:html={title} />}
				{!suppressTitle && (
					<h2 class="content-subtitle" data-toc-ignore set:html={description} />
				)}
				<slot name="after-title" />
			</header>
			{!suppressTitle && <hr class="divider" />}
			<slot />
			<slot name="after-content" />
		</section>
	</article>
</div>

<style>
	.content-subtitle {
		font-weight: 400;
		font-size: 1.5rem;
	}

	.divider {
		opacity: 0.6;
		border: 0;
		border-color: var(--chakra-colors-gray-300);
		border-style: solid;
		border-bottom-width: 1px;
		width: 100%;
		margin-top: 28px !important;
		margin-bottom: 32px;
	}

	.content-title :global(.scope) {
		font-weight: 300;
		color: var(--theme-text-lighter);
	}
	.content {
		padding-top: calc(var(--theme-navbar-height) + var(--doc-padding-block));
		padding-bottom: var(--doc-padding-block);
		padding-inline: var(--min-spacing-inline);
		max-width: 74rem;
		width: 100%;
		height: 100%;
		margin-inline: auto;
		display: flex;
		flex-direction: column;
		overflow-x: hidden;
		font-size: var(--theme-text-lg);
		font-weight: 400;
		letter-spacing: normal;
	}
	.content > section {
		margin-bottom: 4rem;
	}
	:global(.page-heading-bar) {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 0.75rem;
		align-items: center;
		margin-bottom: 2rem;
	}
	:global(.page-heading-bar__breadcrumbs) {
		min-width: 0;
		position: relative;
	}
	:global(.page-heading-bar__breadcrumbs .breadcrumbs) {
		margin: 0;
		display: inline-flex;
		align-items: center;
		width: 100%;
	}
	:global(.page-heading-bar__breadcrumbs .breadcrumbs ol) {
		display: flex;
		flex-wrap: wrap;
		gap: 0.25rem;
		row-gap: 0.15rem;
		padding: 0;
		overflow: visible;
	}
	:global(.page-heading-bar__breadcrumbs .breadcrumbs li) {
		max-width: none;
		flex-shrink: 1;
		white-space: normal;
		overflow: visible;
		text-overflow: clip;
	}
	:global(.docs-toolbar-actions--heading) {
		display: inline-flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		justify-content: flex-end;
		flex: 0 0 auto;
	}
	.next-previous-nav {
		display: flex;
		flex-wrap: wrap;
		width: auto;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	@media (min-width: 50em) {
		.content {
			overflow-x: visible;
		}
	}

	@media (max-width: var(--docs-toolbar-mobile-breakpoint)) {
		:global(.page-heading-bar) {
			grid-template-columns: 1fr;
		}
		:global(.docs-toolbar-actions--heading) {
			width: 100%;
			justify-content: flex-start;
		}
	}
</style>
