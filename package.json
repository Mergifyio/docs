    "js-yaml": "^4.2.0",
    "jsonpointer": "^5.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-format": "^5.0.1",
